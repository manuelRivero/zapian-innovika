{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "ES2020"],
    "jsx": "react",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "baseUrl": "."
  },
  "include": ["src/**/*", "gatsby-*.ts", "gatsby-*.tsx"],
  "exclude": ["node_modules", "public", ".cache"]
}
